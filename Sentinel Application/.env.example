# ============================================================
# Sentinel — Environment Configuration Template
# Copy this to .env and fill in your values. NEVER commit .env
# ============================================================

# --- App ---
APP_NAME=Sentinel
APP_ENV=development           # development | production
DEBUG=true
SECRET_KEY=your-secret-key-here   # generate: openssl rand -hex 32

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=Sentinel
FRONTEND_ORIGIN=http://localhost:5173

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-...      # https://console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2048

# --- Groq (Llama) API ---
GROQ_API_KEY=gsk_...              # https://console.groq.com (free tier available)

# --- Deepfake Detection APIs ---
# Primary detection (Hive Moderation or equivalent)
DETECTION_API_KEY=your-detection-api-key
DETECTION_API_URL=https://api.thehive.ai/api/v2/task/sync
DETECTION_CONFIDENCE_THRESHOLD=0.75

# --- Metadata Enrichment ---
# Google Safe Browsing (URL reputation)
GOOGLE_SAFE_BROWSING_KEY=your-gsb-key

# VirusTotal (file hash lookup)
VIRUSTOTAL_API_KEY=your-vt-key

# --- Database ---
DATABASE_URL=sqlite:///./data/sentinel.db
# For production Postgres: postgresql://user:pass@host:5432/sentinel

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200
MAX_FILE_SIZE_MB=50

# --- Telemetry ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/sentinel.log

# --- Auth (Optional: for multi-user mode) ---
ENABLE_AUTH=false
JWT_SECRET=your-jwt-secret
JWT_EXPIRE_MINUTES=60

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
